<Window x:Class="MíchátkoKoloru.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MíchátkoKoloru"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
       >
    <Canvas>
        <Rectangle Name="Rect" Canvas.Left="68" Canvas.Top="82" Width="310" Height="286" Fill="Red"/>

        <Slider Value="0" Name="SliderRed" Minimum="0" Maximum="255"
                IsSnapToTickEnabled="True" TickFrequency="1"
                ValueChanged="SliderChange"
                Canvas.Left="394" Canvas.Top="171" Width="270"/>

        <Slider Value="0" Name="SliderGreen" Minimum="0" Maximum="255"
                IsSnapToTickEnabled="True" TickFrequency="1"
                ValueChanged="SliderChange"
                Canvas.Left="394" Canvas.Top="248" Width="270"/>

        <Slider Value="0" Name="SliderBlue" Minimum="0" Maximum="255"
                IsSnapToTickEnabled="True" TickFrequency="1"
                ValueChanged="SliderChange"
                Canvas.Left="394" Canvas.Top="327" Width="270"/>

        <TextBlock Canvas.Left="394" Canvas.Top="129" Background="Red" FontSize="22" TextAlignment="Center">
            <Run Language="cs-cz" Text="RED"/>
        </TextBlock>

        <TextBlock Canvas.Left="394" Canvas.Top="207" Background="Lime" FontSize="22" TextAlignment="Center" Text="GREEN"/>
        <TextBlock Canvas.Left="394" Canvas.Top="283" Background="Blue" FontSize="22" TextAlignment="Center" Text="BLUE"/>

        <TextBlock Canvas.Left="394" Canvas.Top="82" Text="Míchátko Barev" FontSize="28" Width="213" FontWeight="Bold"/>

        <Button Canvas.Left="372" Canvas.Top="396" Width="123" Height="34" Name="RandomButt" Click="Random" Content="Random"/>
        <Button Canvas.Left="512" Canvas.Top="396" Width="123" Height="34" Name="LavalampButt" Click="Lavalamp" Content="Lavalamp"/>
        <Button Canvas.Left="647" Canvas.Top="396" Width="123" Height="34" Name="PartyButt" Click="Party" Content="Party"/>

        <TextBox Name="TextboxRed" Canvas.Left="472" Canvas.Top="129" Width="34" Height="22" PreviewTextInput="PreviewNumInput" FontSize="16" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Text="0"/>
        <TextBox Name="TextboxGreen" Canvas.Left="472" Canvas.Top="207" Width="34" Height="22" PreviewTextInput="PreviewNumInput" FontSize="16" Text="0"/>
        <TextBox Name="TextboxBlue" Canvas.Left="472" Canvas.Top="283" Width="34" Height="22" PreviewTextInput="PreviewNumInput" FontSize="16" Text="0"/>
    </Canvas>
</Window>
