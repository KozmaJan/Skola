<Window x:Class="Hry.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Hry.ViewModel"
        mc:Ignorable="d"
        Title="Hledač min"
        Height="450"
        Width="400">

    <!-- ViewModel -->
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <DockPanel Margin="10">

        <!-- Horní panel -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">

            <Button Content="Start"
                    Width="80"
                    Margin="0,0,10,0"
                    Command="{Binding StartCommand}"/>

            <TextBlock Text="Skóre:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <TextBlock Text="{Binding Score}"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel>
            <TextBlock Canvas.Left="394" Canvas.Top="129"  FontSize="22" TextAlignment="Center">
            <Run Language="cs-cz" Text="Výška:"/>
            </TextBlock>
            <TextBox x:Name="TextboxHeight" Width="34" Height="22" PreviewTextInput="PreviewNumInput" FontSize="16" Text="0"/>
            <Slider Value="8" x:Name="SliderHeight" Minimum="4" Maximum="30"
                IsSnapToTickEnabled="True" TickFrequency="1"
                ValueChanged="SliderChange"
                Width="270"/>

            <TextBlock Canvas.Left="394" Canvas.Top="207"  FontSize="22" TextAlignment="Center" Text="Šířka:"/>
            <TextBox x:Name="TextboxWidth" Width="34" Height="22" PreviewTextInput="PreviewNumInput" FontSize="16" Text="0"/>
            <Slider Value="8" x:Name="SliderWidth" Minimum="4" Maximum="30"
                IsSnapToTickEnabled="True" TickFrequency="1"
                ValueChanged="SliderChange"
                Width="270"/>
            <TextBlock Canvas.Left="394" Canvas.Top="283"  FontSize="22" TextAlignment="Center" Text="Počet Min:"/>
            <TextBox x:Name="TextboxMineCount" Width="34" Height="22" PreviewTextInput="PreviewNumInput" FontSize="16" Text="0"/>
            <Slider Value="13" x:Name="SliderBombs" Minimum="0" Maximum="270"
                IsSnapToTickEnabled="True" TickFrequency="1"
                ValueChanged="SliderChange"
                Width="270"/>
        </StackPanel>

        <!-- Herní plocha -->
        <ItemsControl ItemsSource="{Binding Tiles}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <!-- 8x8 grid -->
                    <UniformGrid Rows="8" Columns="8"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="2"
                            FontWeight="Bold"
                            Command="{Binding DataContext.TileClickCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="LightGray"/>
                                <Setter Property="Content" Value=""/>

                                <Style.Triggers>

                                    <!-- Odkryté pole -->
                                    <DataTrigger Binding="{Binding Revealed}" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                    </DataTrigger>


                                    <!-- Číslo sousedů -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Revealed}" Value="True"/>
                                            <Condition Binding="{Binding Bomb}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Content" Value="{Binding Neighbours}"/>
                                    </MultiDataTrigger>

                                    <!-- Mina -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Revealed}" Value="True"/>
                                            <Condition Binding="{Binding Bomb}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Content" Value="💣"/>
                                        <Setter Property="Background" Value="Tomato"/>
                                    </MultiDataTrigger>

                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </DockPanel>
</Window>